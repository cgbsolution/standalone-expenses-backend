# =============================================================
# Backend configuration — copy this file to .env and fill in.
# .env is gitignored. NEVER commit real secrets.
# =============================================================

# --- Server ------------------------------------------------------
PORT=5000
BASE_URL=http://localhost:5000

# --- Supabase Postgres (required — server crashes without this) -
# Direct connection. Get the password from:
#   Supabase Dashboard → Project Settings → Database → Database password
# Use the pooler URL for serverless deployments; direct is fine for a single
# Node process.
DATABASE_URL=postgresql://postgres:<DB_PASSWORD>@db.<PROJECT_REF>.supabase.co:5432/postgres

# --- Supabase REST credentials ----------------------------------
# Set these when you need supabase-js (storage / realtime / RLS).
SUPABASE_URL=https://<PROJECT_REF>.supabase.co
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_SECRET_KEY=

# --- Employee directory lookup ----------------------------------
EMPLOYEE_INFO_URL=

# =============================================================
# Notifier configuration
# =============================================================

# Provider: only "smtp" is supported now.
NOTIFY_PROVIDER=smtp

# --- SMTP --------------------------------------------------------
# Port 465 → SMTP_SECURE=true (implicit TLS)
# Port 587 → SMTP_SECURE=false (STARTTLS)
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=""
SMTP_FROM=
# Set to "false" only for internal servers with self-signed certs.
SMTP_TLS_REJECT_UNAUTHORIZED=true

# --- Smoke test recipient ---------------------------------------
# Default = whoever is in SMTP_USER (sender mails themselves).
NOTIFY_TEST_TO=

# --- Feature flag for outbound notifications --------------------
NOTIFY_ENABLED=false
